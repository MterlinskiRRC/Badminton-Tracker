PORT=3000
NODE_ENV=development
CORS_ORIGIN=
FIREBASE_CHECK_REVOKED=true
# Option 1: point to a Firebase Admin service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=
# Option 2: use the standard Google credentials env var instead.
GOOGLE_APPLICATION_CREDENTIALS=
# Option 3: provide the raw service account fields directly.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""
