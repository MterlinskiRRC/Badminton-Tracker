{
    "openapi": "3.0.3",
    "info": {
        "title": "Badminton Score Tracker API",
        "version": "0.1.0",
        "description": "Milestone 1 API documentation for players, matches, rankings, and analytics.\n\nAuthentication:\n- All /api/v1 endpoints require a Firebase ID token.\n- Click Authorize in Swagger UI and provide: Bearer <FIREBASE_ID_TOKEN>.\n- /health and /docs are public.\n- The API requires Firebase Admin credentials at startup."
    },
    "servers": [
        {
            "url": "http://localhost:3000",
            "description": "Local development"
        }
    ],
    "tags": [
        { "name": "Health" },
        { "name": "Players" },
        { "name": "Matches" },
        { "name": "Rankings" },
        { "name": "Analytics" }
    ],
    "paths": {
        "/health": {
            "get": {
                "tags": ["Health"],
                "summary": "API health check",
                "responses": {
                    "200": {
                        "description": "Service is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessEnvelope"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/players": {
            "post": {
                "tags": ["Players"],
                "summary": "Create a new player",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/CreatePlayer" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Player created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": {
                                                    "$ref": "#/components/schemas/Player"
                                                },
                                                "message": {
                                                    "type": "string",
                                                    "example": "Player created"
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "400": { "$ref": "#/components/responses/BadRequest" },
                    "401": { "$ref": "#/components/responses/Unauthorized" }
                }
            },
            "get": {
                "tags": ["Players"],
                "summary": "List all players",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "Player list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": {
                                                    "type": "array",
                                                    "items": { "$ref": "#/components/schemas/Player" }
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" }
                }
            }
        },
        "/api/v1/players/{id}": {
            "get": {
                "tags": ["Players"],
                "summary": "Get player by id",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
                "responses": {
                    "200": {
                        "description": "Player found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": { "$ref": "#/components/schemas/Player" }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            },
            "patch": {
                "tags": ["Players"],
                "summary": "Update player (admin)",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/UpdatePlayer" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Player updated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": { "$ref": "#/components/schemas/Player" },
                                                "message": {
                                                    "type": "string",
                                                    "example": "Player updated"
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "400": { "$ref": "#/components/responses/BadRequest" },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            },
            "delete": {
                "tags": ["Players"],
                "summary": "Delete player (admin)",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
                "responses": {
                    "204": { "description": "Player deleted" },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            }
        },
        "/api/v1/matches": {
            "post": {
                "tags": ["Matches"],
                "summary": "Record a match result",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/CreateMatch" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Match created",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": { "$ref": "#/components/schemas/Match" },
                                                "message": {
                                                    "type": "string",
                                                    "example": "Match recorded"
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "400": { "$ref": "#/components/responses/BadRequest" },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            },
            "get": {
                "tags": ["Matches"],
                "summary": "List all matches",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "Match list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": {
                                                    "type": "array",
                                                    "items": { "$ref": "#/components/schemas/Match" }
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" }
                }
            }
        },
        "/api/v1/matches/{id}": {
            "get": {
                "tags": ["Matches"],
                "summary": "Get match by id",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
                "responses": {
                    "200": {
                        "description": "Match found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": { "$ref": "#/components/schemas/Match" }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                }
            }
        },
        "/api/v1/rankings": {
            "get": {
                "tags": ["Rankings"],
                "summary": "Generate live player rankings",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "Ranking list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": {
                                                    "type": "array",
                                                    "items": { "$ref": "#/components/schemas/Ranking" }
                                                }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" }
                }
            }
        },
        "/api/v1/analytics": {
            "get": {
                "tags": ["Analytics"],
                "summary": "Get analytics summary (admin)",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "Analytics summary",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        { "$ref": "#/components/schemas/SuccessEnvelope" },
                                        {
                                            "properties": {
                                                "data": { "$ref": "#/components/schemas/AnalyticsSummary" }
                                            }
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "Firebase Authentication ID token.\n\nHeader format: Authorization: Bearer <FIREBASE_ID_TOKEN>"
            }
        },
        "parameters": {
            "IdPath": {
                "name": "id",
                "in": "path",
                "required": true,
                "schema": { "type": "string" }
            }
        },
        "responses": {
            "BadRequest": {
                "description": "Bad request",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
                    }
                }
            },
            "Unauthorized": {
                "description": "Unauthorized",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
                    }
                }
            },
            "Forbidden": {
                "description": "Forbidden",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
                    }
                }
            },
            "NotFound": {
                "description": "Not found",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/ErrorEnvelope" }
                    }
                }
            }
        },
        "schemas": {
            "SuccessEnvelope": {
                "type": "object",
                "required": ["success", "timestamp"],
                "properties": {
                    "success": { "type": "boolean", "example": true },
                    "data": {},
                    "message": { "type": "string" },
                    "timestamp": { "type": "string", "format": "date-time" }
                }
            },
            "ErrorEnvelope": {
                "type": "object",
                "required": ["success", "error", "timestamp"],
                "properties": {
                    "success": { "type": "boolean", "example": false },
                    "error": {
                        "type": "object",
                        "required": ["message", "code"],
                        "properties": {
                            "message": { "type": "string" },
                            "code": { "type": "string" }
                        }
                    },
                    "timestamp": { "type": "string", "format": "date-time" }
                }
            },
            "CreatePlayer": {
                "type": "object",
                "required": ["name"],
                "properties": {
                    "name": { "type": "string" }
                }
            },
            "UpdatePlayer": {
                "type": "object",
                "properties": {
                    "name": { "type": "string" }
                }
            },
            "Player": {
                "type": "object",
                "required": ["id", "name", "totalWins", "totalLosses", "winPercentage", "createdAt", "updatedAt"],
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "totalWins": { "type": "number" },
                    "totalLosses": { "type": "number" },
                    "winPercentage": { "type": "number" },
                    "createdAt": { "type": "string" },
                    "updatedAt": { "type": "string" }
                }
            },
            "CreateMatch": {
                "type": "object",
                "required": ["playerId", "opponentId", "result"],
                "properties": {
                    "playerId": { "type": "string" },
                    "opponentId": { "type": "string" },
                    "result": { "type": "string", "enum": ["win", "loss"] },
                    "playedAt": { "type": "string", "format": "date-time" }
                }
            },
            "Match": {
                "type": "object",
                "required": ["id", "playerId", "opponentId", "result", "playedAt", "createdAt"],
                "properties": {
                    "id": { "type": "string" },
                    "playerId": { "type": "string" },
                    "opponentId": { "type": "string" },
                    "result": { "type": "string", "enum": ["win", "loss"] },
                    "playedAt": { "type": "string" },
                    "createdAt": { "type": "string" }
                }
            },
            "Ranking": {
                "type": "object",
                "required": ["playerId", "playerName", "rankingScore", "position", "totalWins", "totalLosses", "winPercentage"],
                "properties": {
                    "playerId": { "type": "string" },
                    "playerName": { "type": "string" },
                    "rankingScore": { "type": "number" },
                    "position": { "type": "number" },
                    "totalWins": { "type": "number" },
                    "totalLosses": { "type": "number" },
                    "winPercentage": { "type": "number" }
                }
            },
            "AnalyticsSummary": {
                "type": "object",
                "required": ["matchesRecorded", "mostActivePlayers"],
                "properties": {
                    "matchesRecorded": { "type": "number" },
                    "mostActivePlayers": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": ["playerId", "matchCount"],
                            "properties": {
                                "playerId": { "type": "string" },
                                "matchCount": { "type": "number" }
                            }
                        }
                    }
                }
            }
        }
    }
}
